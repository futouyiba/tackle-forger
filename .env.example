# 飞书网页 OAuth（FEISHU_REDIRECT_URI 必须与开放平台登记值逐字一致）
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_TENANT_KEY=
FEISHU_REDIRECT_URI=https://tackle-forger.example.com/api/auth/feishu/callback
# 仅在无 HTTPS 的受控私网 IP 部署中显式开启；公网 HTTP 地址始终拒绝。
FEISHU_ALLOW_INSECURE_HTTP=false
FEISHU_SESSION_SECRET=
FEISHU_SESSION_TTL_SECONDS=28800
TACKLE_FORGER_SUPPORT_URL=
FEISHU_OPEN_API_BASE_URL=https://open.feishu.cn
FEISHU_ACCOUNTS_BASE_URL=https://accounts.feishu.cn
FEISHU_OAUTH_SCOPES=contact:user.base:readonly

# 耐久会话目录；生产环境必须挂载到受备份保护、仅服务账号可读写的持久磁盘。
FEISHU_SESSION_DATA_DIR=.data/auth

# 可选的可信反向代理兼容。默认关闭；仅在浏览器无法直达源站、网关会剥离并重写
# x-feishu-* 与 x-tf-proxy-secret 时启用。共享密钥只配置在网关和服务端。
FEISHU_TRUST_PROXY_HEADERS=false
FEISHU_PROXY_SHARED_SECRET=

# 可选 Fancy Hub AI 连接器。真实连接器默认关闭；只有地址、凭据、主/降级模型和
# provider/租户硬限额全部配置并通过运行时模型修订校验后才允许启用。
FANCY_HUB_ENABLED=false
FANCY_HUB_BASE_URL=
FANCY_HUB_API_TOKEN=
FANCY_HUB_PRIMARY_MODEL_ID=
FANCY_HUB_FALLBACK_MODEL_IDS=
FANCY_HUB_TENANT_MAX_INPUT_TOKENS=
FANCY_HUB_TENANT_MAX_OUTPUT_TOKENS=
FANCY_HUB_TENANT_MAX_CONCURRENT_REQUESTS=
FANCY_HUB_TENANT_MAX_REQUESTS_PER_MINUTE=
FANCY_HUB_REQUEST_TIMEOUT_MS=
FANCY_HUB_TENANT_MAX_COST_MICRO_USD_PER_REQUEST=
# 出网前按 canonical UTF-8 字节上界和部署批准的最高费率确定性估算。
FANCY_HUB_ASSESSMENT_MAX_OUTPUT_TOKENS=
FANCY_HUB_MAX_INPUT_COST_MICRO_USD_PER_1K_TOKENS=
FANCY_HUB_MAX_OUTPUT_COST_MICRO_USD_PER_1K_TOKENS=
# 真实 AI 启用时必填；目录必须位于持久磁盘，密钥为 32 字节 Base64。
AI_RETENTION_DATA_DIR=.data/ai
AI_RETENTION_ENCRYPTION_KEY_BASE64=
AI_RETENTION_ENCRYPTION_KEY_VERSION=
# 只有列出的部署管理员获得 ai.provider_policy.manage。
AI_PROVIDER_ADMIN_OPEN_IDS=

# FEISHU_LOGIN_URL 已废弃；直接 OAuth 不读取该变量。


# Node/R730 persistent workspace storage
WORKSPACE_DATABASE_PATH=.data/workspace.sqlite
WORKSPACE_FILE_DATA_DIR=.data/files
WORKSPACE_BACKUP_DIR=.data/backups
WORKSPACE_BACKUP_RETENTION_DAYS=30

# 旧版 pnpm 工作区兼容变量；仅运行 apps/web 时需要。
DATABASE_URL=postgresql://tackle_forger:tackle_forger@localhost:5432/tackle_forger
AUTH_SECRET=replace-with-at-least-32-random-characters
