# 飞书网页 OAuth（FEISHU_REDIRECT_URI 必须与开放平台登记值逐字一致）
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_TENANT_KEY=
FEISHU_REDIRECT_URI=https://tackle-forger.example.com/api/auth/feishu/callback
# 仅在无 HTTPS 的受控私网 IP 部署中显式开启；公网 HTTP 地址始终拒绝。
FEISHU_ALLOW_INSECURE_HTTP=false
FEISHU_SESSION_SECRET=
FEISHU_SESSION_TTL_SECONDS=28800
TACKLE_FORGER_SUPPORT_URL=
FEISHU_OPEN_API_BASE_URL=https://open.feishu.cn
FEISHU_ACCOUNTS_BASE_URL=https://accounts.feishu.cn
FEISHU_OAUTH_SCOPES=contact:user.base:readonly

# 耐久会话目录；生产环境必须挂载到受备份保护、仅服务账号可读写的持久磁盘。
FEISHU_SESSION_DATA_DIR=.data/auth

# 可选的可信反向代理兼容。默认关闭；仅在浏览器无法直达源站、网关会剥离并重写
# x-feishu-* 与 x-tf-proxy-secret 时启用。共享密钥只配置在网关和服务端。
FEISHU_TRUST_PROXY_HEADERS=false
FEISHU_PROXY_SHARED_SECRET=

# FEISHU_LOGIN_URL 已废弃；直接 OAuth 不读取该变量。


# Node/R730 persistent workspace storage
WORKSPACE_DATABASE_PATH=.data/workspace.sqlite
WORKSPACE_FILE_DATA_DIR=.data/files
WORKSPACE_BACKUP_DIR=.data/backups
WORKSPACE_BACKUP_RETENTION_DAYS=30