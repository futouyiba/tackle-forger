server {
    listen 443 ssl http2;
    server_name tackle-forger.internal.example;

    # 证书路径由公司内网 PKI/运维替换。
    ssl_certificate     /etc/nginx/tls/tackle-forger.crt;
    ssl_certificate_key /etc/nginx/tls/tackle-forger.key;

    client_max_body_size 50m;
    proxy_read_timeout 120s;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Real-IP $remote_addr;

        # This topology uses direct Feishu OAuth. Never forward identity headers
        # supplied by an external client to the application.
        proxy_set_header X-Feishu-Tenant-Key "";
        proxy_set_header X-Feishu-Open-Id "";
        proxy_set_header X-Feishu-Display-Name "";
        proxy_set_header X-TF-Proxy-Secret "";
    }
}
