# R730 production environment template. Copy to /opt/tackle-forger/.env.local
# and keep the resulting file readable only by the tackleforger service account.
NODE_ENV=production

FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_TENANT_KEY=
# Resolved spreadsheet token for the registered canonical workbook; keep it server-side.
FEISHU_CANONICAL_SPREADSHEET_TOKEN=
FEISHU_REDIRECT_URI=https://tackle-forger.internal.example/api/auth/feishu/callback
FEISHU_ALLOW_INSECURE_HTTP=false
FEISHU_SESSION_SECRET=
FEISHU_SESSION_TTL_SECONDS=28800
TACKLE_FORGER_SUPPORT_URL=
FEISHU_OPEN_API_BASE_URL=https://open.feishu.cn
FEISHU_ACCOUNTS_BASE_URL=https://accounts.feishu.cn
FEISHU_OAUTH_SCOPES=contact:user.base:readonly
FEISHU_SESSION_DATA_DIR=/opt/tackle-forger/data/auth

# Keep proxy-header authentication disabled for this direct OAuth topology.
FEISHU_TRUST_PROXY_HEADERS=false
FEISHU_PROXY_SHARED_SECRET=

WORKSPACE_DATABASE_PATH=/opt/tackle-forger/data/workspace.sqlite
WORKSPACE_FILE_DATA_DIR=/opt/tackle-forger/data/files
WORKSPACE_BACKUP_DIR=/opt/tackle-forger/data/backups
WORKSPACE_BACKUP_RETENTION_DAYS=30

# Full merged commit SHAs for the three phase-one deployment dependencies.
# Populate only after the corresponding PR has passed substantive review and CI.
PHASE_ONE_CANONICAL_PULL_COMMIT=
PHASE_ONE_SCHEMA_V17_COMMIT=
PHASE_ONE_NON_FORMAL_COMMIT=
