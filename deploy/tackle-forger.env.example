# R730 production environment template. Copy to /opt/tackle-forger/.env.local
# and keep the resulting file readable only by the tackleforger service account.
NODE_ENV=production

FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_TENANT_KEY=
# Resolved spreadsheet token for the registered canonical workbook; keep it server-side.
FEISHU_CANONICAL_SPREADSHEET_TOKEN=
FEISHU_REDIRECT_URI=https://tackle-forger.internal.example/api/auth/feishu/callback
FEISHU_ALLOW_INSECURE_HTTP=false
FEISHU_SESSION_SECRET=
FEISHU_SESSION_TTL_SECONDS=28800
TACKLE_FORGER_SUPPORT_URL=
FEISHU_OPEN_API_BASE_URL=https://open.feishu.cn
FEISHU_ACCOUNTS_BASE_URL=https://accounts.feishu.cn
FEISHU_OAUTH_SCOPES=contact:user.base:readonly
FEISHU_SESSION_DATA_DIR=/opt/tackle-forger/data/auth
# Phase-one dependency gate: GitHub token with read-only repository metadata and GraphQL access.
# Never grant write, Issue, deployment, administration, or workflow-management permissions.
GITHUB_ACCEPTANCE_TOKEN=

# Keep proxy-header authentication disabled for this direct OAuth topology.
FEISHU_TRUST_PROXY_HEADERS=false
FEISHU_PROXY_SHARED_SECRET=

# Fancy Hub 默认关闭。上线前必须配置全部硬限额、动态模型与管理员，并保留启用/回滚证据。
FANCY_HUB_ENABLED=false
FANCY_HUB_BASE_URL=
FANCY_HUB_API_TOKEN=
FANCY_HUB_PRIMARY_MODEL_ID=
FANCY_HUB_FALLBACK_MODEL_IDS=
FANCY_HUB_PROVIDER_MAX_INPUT_TOKENS=
FANCY_HUB_PROVIDER_MAX_OUTPUT_TOKENS=
FANCY_HUB_PROVIDER_MAX_CONCURRENT_REQUESTS=
FANCY_HUB_PROVIDER_MAX_REQUESTS_PER_MINUTE=
FANCY_HUB_PROVIDER_REQUEST_TIMEOUT_MS=
FANCY_HUB_PROVIDER_MAX_COST_MICRO_USD_PER_REQUEST=
FANCY_HUB_TENANT_MAX_INPUT_TOKENS=
FANCY_HUB_TENANT_MAX_OUTPUT_TOKENS=
FANCY_HUB_TENANT_MAX_CONCURRENT_REQUESTS=
FANCY_HUB_TENANT_MAX_REQUESTS_PER_MINUTE=
FANCY_HUB_REQUEST_TIMEOUT_MS=
FANCY_HUB_TENANT_MAX_COST_MICRO_USD_PER_REQUEST=
FANCY_HUB_ASSESSMENT_MAX_OUTPUT_TOKENS=
FANCY_HUB_MAX_INPUT_COST_MICRO_USD_PER_1K_TOKENS=
FANCY_HUB_MAX_OUTPUT_COST_MICRO_USD_PER_1K_TOKENS=
AI_PROVIDER_ADMIN_OPEN_IDS=

# AI 原始/语义内容、操作元数据及删除墓碑的持久留存。密钥必须是 32 字节 Base64。
AI_RETENTION_DATA_DIR=/opt/tackle-forger/data/ai-retention
# 独立于 ai-retention 备份恢复域；不得从旧工作区备份覆盖。
AI_RETENTION_TOMBSTONE_DIR=/opt/tackle-forger/data/ai-deletion-tombstones
AI_RETENTION_ENCRYPTION_KEY_BASE64=
AI_RETENTION_ENCRYPTION_KEY_VERSION=

WORKSPACE_DATABASE_PATH=/opt/tackle-forger/data/workspace.sqlite
WORKSPACE_FILE_DATA_DIR=/opt/tackle-forger/data/files
WORKSPACE_BACKUP_DIR=/opt/tackle-forger/data/backups
WORKSPACE_BACKUP_RETENTION_DAYS=30
